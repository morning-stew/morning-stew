{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "grep": {
      "type": "local",
      "command": ["npx", "-y", "mcp-ripgrep"],
      "enabled": true
    },
    "deepwiki": {
      "type": "local",
      "command": ["npx", "-y", "@physihan/deepwiki-mcp@latest"],
      "enabled": true
    },
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server"],
      "enabled": true
    }
  }
}
